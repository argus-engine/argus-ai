# ---------------------------------------------------------------------------
# Default environment for docker compose. Committed to the repo because the
# only thing it does is activate the `cpu` profile by default so that
# `docker compose up` works without flags. Per-developer secrets and any
# local overrides must live in `.env.local` (gitignored) — never here.
# ---------------------------------------------------------------------------

# Activates the `cpu` profile so `docker compose up` brings up:
#   api (cpu), neo4j (with APOC), streamlit
# Override at the shell to use the GPU stack instead:
#   docker compose --profile gpu up
COMPOSE_PROFILES=cpu
