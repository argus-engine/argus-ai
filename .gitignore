# ---- Project ----
# Real datasets are downloaded by scripts/download_data.py and land in the
# repo-root /data/ directory. Anchor with a leading slash so the rule does
# not accidentally swallow `argus/domain_packs/<pack>/data/` source modules.
/data/
!tests/fixtures/

# Local environment overrides.
# The project-root `.env` IS committed — it sets the default
# docker-compose profile (`COMPOSE_PROFILES=cpu`). Real secrets must live
# in `.env.local`, which is gitignored below.
.env.*
!.env.example

# Logs and artifacts
logs/
*.log
artifacts/
runs/
wandb/
mlruns/

# Secrets — defensive belt-and-braces
*.pem
*.key
credentials.json
kaggle.json
# Local-only GitHub PAT for CI log fetches (Actions:Read scope).
.github_token.txt
